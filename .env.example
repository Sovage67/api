# ========================================
# Repo : api
# Copie ce fichier en .env et remplis les valeurs.
# Ne JAMAIS commit le fichier .env dans Git.
# ========================================

# --- Bot Token (pour récupérer salons/rôles et page Status) ---
# DISCORD_TOKEN est le nom canonique (partagé avec le repo bot/).
# BOT_TOKEN est accepté comme alias historique.
DISCORD_TOKEN=ton_token_de_bot_discord

# --- Discord OAuth2 ---
DISCORD_CLIENT_ID=id_de_ton_application
DISCORD_CLIENT_SECRET=ton_client_secret_oauth2
# IMPORTANT : doit correspondre à une URL ajoutée dans Discord Developer Portal → OAuth2 → Redirects
# En dev local : http://localhost:3001/api/auth/callback
# En prod (via Vercel rewrite) : https://[ton-dashboard].vercel.app/api/auth/callback
DISCORD_REDIRECT_URI=http://localhost:3001/api/auth/callback

# --- Base de données (Supabase) ---
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# --- Redis (Upstash) ---
REDIS_URL=rediss://default:[token]@[endpoint].upstash.io:6379

# --- Serveur HTTP ---
# Render injecte automatiquement PORT en prod, sinon API_PORT en local
API_PORT=3001
# Long secret aléatoire pour signer les sessions (64 caractères minimum)
SESSION_SECRET=remplace_par_une_chaine_aleatoire_longue_et_secrete_64_chars_minimum
# Domaine du cookie (laisser vide pour qu'il prenne le domaine de la requête)
COOKIE_DOMAIN=
# Origine(s) autorisée(s) par CORS, séparées par des virgules
CORS_ORIGIN=http://localhost:3000,https://[ton-dashboard].vercel.app

# --- Stripe (premium, optionnel) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# --- Environnement ---
NODE_ENV=production
LOG_LEVEL=info
