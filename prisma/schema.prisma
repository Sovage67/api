// Schéma Prisma local au repo "api".
// IMPORTANT : ce fichier doit être identique à bot/prisma/schema.prisma.
// Quand tu modifies le schéma, copie-le dans les deux repos puis fais une migration.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Guild {
  id             String    @id
  name           String
  prefix         String    @default("!")
  language       String    @default("fr")
  premium        Boolean   @default(false)
  premiumUntil   DateTime?
  welcomeChannel String?
  welcomeMessage String?
  leaveChannel   String?
  leaveMessage   String?
  logsChannel    String?
  autoRole       String?
  modules        Json      @default("{\"economy\":true,\"levels\":true,\"moderation\":true}")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  members Member[]
  warns   Warn[]
}

model User {
  id          String   @id
  username    String
  globalCoins Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members       Member[]
  subscriptions Subscription[]
}

model Member {
  guildId   String
  userId    String
  xp        Int       @default(0)
  level     Int       @default(0)
  coins     Int       @default(0)
  bank      Int       @default(0)
  lastDaily DateTime?
  lastWork  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([guildId, userId])
  @@index([guildId, level])
  @@index([guildId, coins])
}

model Warn {
  id        Int      @id @default(autoincrement())
  guildId   String
  userId    String
  modId     String
  reason    String
  createdAt DateTime @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId, userId])
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String
  stripeId  String   @unique
  status    String
  guildIds  String[]
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}
