// Bot Intrepides - Prisma schema (canonical version)
// Keep bot/prisma/schema.prisma and api/prisma/schema.prisma in sync.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Guild {
  id             String    @id
  name           String
  prefix         String    @default("!")
  language       String    @default("fr")
  premium        Boolean   @default(false)
  premiumUntil   DateTime?

  // Identite de la licence freemium
  installerUserId String?
  ownerUserId     String?
  licenseHolderId String?
  licenseFrozen   Boolean  @default(false)

  // Welcome / Goodbye
  welcomeChannel String?
  welcomeMessage String?
  leaveChannel   String?
  leaveMessage   String?

  // Moderation / Logs
  logsChannel String?
  autoRole    String?

  // Tickets
  ticketCategory      String?
  ticketSupportRole   String?
  ticketOpenMessage   String?
  ticketVoice         Boolean @default(false)
  ticketVoiceCategory String?

  // Bot personnalise
  botNickname    String?
  botDescription String?

  // Translation
  translationTarget String @default("fr")

  // Stats / member logs
  statsChannel      String?
  memberLogsChannel String?

  // DATABASE ID
  databaseIdAdminRole String?

  // Modules (JSON map). Default empty - filled by app code.
  modules Json @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members Member[]
  warns   Warn[]

  @@index([installerUserId])
  @@index([licenseHolderId])
}

model User {
  id          String   @id
  username    String
  globalCoins Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members       Member[]
  subscriptions Subscription[]
}

model Member {
  guildId   String
  userId    String
  xp        Int       @default(0)
  level     Int       @default(0)
  coins     Int       @default(0)
  bank      Int       @default(0)
  lastDaily DateTime?
  lastWork  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([guildId, userId])
  @@index([guildId, level])
  @@index([guildId, coins])
}

model Warn {
  id        Int      @id @default(autoincrement())
  guildId   String
  userId    String
  modId     String
  reason    String
  createdAt DateTime @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId, userId])
}

model MemberLog {
  id        Int      @id @default(autoincrement())
  guildId   String
  userId    String
  username  String
  type      String
  createdAt DateTime @default(now())

  @@index([guildId, userId])
  @@index([userId, createdAt])
  @@index([guildId, type, createdAt])
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String
  stripeId  String   @unique
  status    String
  guildIds  String[]
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model DashboardSession {
  id        String   @id @default(cuid())
  userId    String
  guildId   String?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([ip, createdAt])
  @@index([guildId])
}

model GuildRiskScore {
  guildId    String   @id
  score      Int      @default(0)
  reasons    Json     @default("[]")
  flagged    Boolean  @default(false)
  computedAt DateTime @default(now())

  @@index([flagged, score])
}

model MessageActivity {
  id      Int      @id @default(autoincrement())
  guildId String
  bucket  DateTime // Tronqué à l'heure UTC
  count   Int      @default(0)

  @@unique([guildId, bucket])
  @@index([guildId, bucket])
}

model ReactionActivity {
  id      Int      @id @default(autoincrement())
  guildId String
  bucket  DateTime // Tronqué à l'heure UTC
  count   Int      @default(0)

  @@unique([guildId, bucket])
  @@index([guildId, bucket])
}
