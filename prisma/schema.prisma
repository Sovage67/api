// Bot Intrepides - Prisma schema (canonical version)
// Keep bot/prisma/schema.prisma and api/prisma/schema.prisma in sync.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Guild {
  id             String    @id
  name           String
  prefix         String    @default("!")
  language       String    @default("fr")
  premium        Boolean   @default(false)
  premiumUntil   DateTime?

  // Identite de la licence freemium
  installerUserId String?
  ownerUserId     String?
  licenseHolderId String?
  licenseFrozen   Boolean  @default(false)

  // Welcome / Goodbye
  welcomeChannel String?
  welcomeMessage String?
  leaveChannel   String?
  leaveMessage   String?

  // Moderation / Logs
  logsChannel String?
  autoRole    String?

  // Tickets
  ticketCategory      String?
  ticketSupportRole   String?
  ticketOpenMessage   String?
  ticketVoice         Boolean @default(false)
  ticketVoiceCategory String?

  // Bot personnalise
  botNickname    String?
  botDescription String?

  // Translation
  translationTarget String @default("fr")

  // Stats / member logs
  statsChannel      String?
  memberLogsChannel String?

  // DATABASE ID
  databaseIdAdminRole String?

  // Modules (JSON map). Default empty - filled by app code.
  modules Json @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members Member[]
  warns   Warn[]

  @@index([installerUserId])
  @@index([licenseHolderId])
}

model User {
  id          String   @id
  username    String
  globalCoins Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members       Member[]
  subscriptions Subscription[]
}

model Member {
  guildId   String
  userId    String
  xp        Int       @default(0)
  level     Int       @default(0)
  coins     Int       @default(0)
  bank      Int       @default(0)
  lastDaily DateTime?
  lastWork  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([guildId, userId])
  @@index([guildId, level])
  @@index([guildId, coins])
}

model Warn {
  id        Int      @id @default(autoincrement())
  guildId   String
  userId    String
  modId     String
  reason    String
  createdAt DateTime @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId, userId])
}

model MemberLog {
  id        Int      @id @default(autoincrement())
  guildId   String
  userId    String
  username  String
  type      String
  createdAt DateTime @default(now())

  @@index([guildId, userId])
  @@index([userId, createdAt])
  @@index([guildId, type, createdAt])
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String
  stripeId  String   @unique
  status    String
  guildIds  String[]
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model DashboardSession {
  id        String   @id @default(cuid())
  userId    String
  guildId   String?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([ip, createdAt])
  @@index([guildId])
}

model GuildRiskScore {
  guildId    String   @id
  score      Int      @default(0)
  reasons    Json     @default("[]")
  flagged    Boolean  @default(false)
  computedAt DateTime @default(now())

  @@index([flagged, score])
}

model MessageActivity {
  id      Int      @id @default(autoincrement())
  guildId String
  bucket  DateTime // Tronqué à l'heure UTC
  count   Int      @default(0)

  @@unique([guildId, bucket])
  @@index([guildId, bucket])
}

model ReactionActivity {
  id      Int      @id @default(autoincrement())
  guildId String
  bucket  DateTime // Tronqué à l'heure UTC
  count   Int      @default(0)

  @@unique([guildId, bucket])
  @@index([guildId, bucket])
}

model AntiInsulteLog {
  id             Int      @id @default(autoincrement())
  guildId        String
  userId         String
  username       String
  word           String
  action         String
  messageContent String
  createdAt      DateTime @default(now())

  @@index([guildId, createdAt])
  @@index([guildId, userId])
}

model AntiRaidConfig {
  id             Int      @id @default(autoincrement())
  guildId        String   @unique
  enabled        Boolean  @default(false)
  // Détection flood d'arrivées
  joinEnabled    Boolean  @default(true)
  joinThreshold  Int      @default(8)   // nb de joins déclencheurs
  joinWindow     Int      @default(3)   // en secondes
  // Détection comptes suspects (trop récents)
  suspectEnabled Boolean  @default(true)
  minAccountAge  Int      @default(7)   // en jours
  // Détection bots API (app qui rejoint sans invitation du fondateur)
  botApiEnabled  Boolean  @default(true)
  // Détection spam de liens multi-canaux
  linkEnabled    Boolean  @default(true)
  linkThreshold  Int      @default(3)   // nb de liens en linkWindow secondes
  linkWindow     Int      @default(5)   // en secondes
  // Action : ban avec purge messages
  banPurgeDays   Int      @default(1)   // 0-7 jours de purge
  // Alertes
  logChannelId   String?
  modPingRoleId  String?
  updatedAt      DateTime @updatedAt

  @@index([guildId])
}

model AntiRaidLog {
  id         Int      @id @default(autoincrement())
  guildId    String
  type       String   // "mass_join" | "suspect_account" | "bot_api" | "link_spam"
  userId     String
  username   String
  accountAge Int?     // en jours (pour suspect_account)
  action     String   // "banned"
  detail     String?  // info complémentaire (lien, nb joins, etc.)
  createdAt  DateTime @default(now())

  @@index([guildId, createdAt])
  @@index([guildId, userId])
}

model TraductionConfig {
  id           Int      @id @default(autoincrement())
  guildId      String   @unique
  enabled      Boolean  @default(false)
  targetLang   String   @default("fr")
  mode         String   @default("reply")      // reply | embed
  channelMode  String   @default("all")         // all | whitelist | blacklist
  channels     String[]
  skipSameLang Boolean  @default(true)
  updatedAt    DateTime @updatedAt

  @@index([guildId])
}

model ArriveesDepartsConfig {
  id              Int      @id @default(autoincrement())
  guildId         String   @unique
  // Bienvenue
  autoRoleEnabled Boolean  @default(false)
  autoRoleId      String?
  welcomeEnabled  Boolean  @default(false)
  welcomeChannel  String?
  welcomeMessage  String   @default("**Bienvenue {user.mention} sur {server.name} !**")
  welcomeFormat   String   @default("embed")   // text | embed
  welcomeMention  Boolean  @default(true)
  // Au revoir
  goodbyeEnabled  Boolean  @default(false)
  goodbyeChannel  String?
  goodbyeMessage  String   @default("😢 **{user.username}** vient de quitter {server.name}...")
  goodbyeFormat   String   @default("embed")   // text | embed
  welcomeImageUrl String?                       // URL image embed bienvenue
  goodbyeImageUrl String?                       // URL image embed au revoir
  updatedAt       DateTime @updatedAt

  @@index([guildId])
}

model AntiInsulteConfig {
  id              Int      @id @default(autoincrement())
  guildId         String   @unique
  enabled         Boolean  @default(false)
  words                String[]
  removedDefaultWords  String[] // mots de la liste par défaut désactivés par le serveur
  action          String   @default("delete") // delete | warn | timeout | kick
  timeoutDuration Int      @default(300)      // secondes (pour action = timeout)
  kickAfterWarns  Int      @default(3)        // nb d'avertissements avant kick (1-5)
  warnMaxCount    Int      @default(1)        // nb d'avertissements personnalisés (1-5)
  warnMessages    String[]                   // messages par niveau d'avertissement (index 0 = warn 1)
  warnDm          Boolean  @default(true)    // envoyer en DM
  exemptRoles     String[]
  exemptChannels  String[]
  logChannelId    String?
  modPingRoleId   String?            // rôle à mentionner dans le salon de logs
  updatedAt       DateTime @updatedAt

  @@index([guildId])
}
